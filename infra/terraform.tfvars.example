# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
project_id      = "imagegenie-pipeline"
region          = "us-central1"
billing_account = "XXXXXX-XXXXXX-XXXXXX"
budget_amount   = 100

# Transactional email — mail_from and resend_api_key are REQUIRED (the deployed
# app must be able to send verification + invite mail).
mail_from      = "ImageGenie <noreply@onboarding.furiousnacho.com>"
resend_api_key = "re_..." # sensitive; goes through Secret Manager, not plain env

# The Cloud Run URL isn't known until the service exists. Leave empty for the first
# apply, then set app_base_url = the api_url output and re-apply so email links
# point at the real host.
app_base_url = ""
