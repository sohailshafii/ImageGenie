# Build context is the repo root (server/Dockerfile builds both the API image and
# the SPA). Keep the context small: exclude everything the build doesn't need.

# Git + OS cruft
.git
.gitignore
**/.DS_Store

# Python: virtualenv, caches, compiled files
.venv
**/__pycache__
**/*.py[cod]
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache
**/*.egg-info

# Node: dependencies are installed fresh via `npm ci` in the build stage, and the
# SPA is compiled in-image — never ship the host's copies.
**/node_modules
web/dist

# Data, local pipeline outputs, and the Objaverse cache are never part of an image
data
render_captures
.objaverse

# Terraform state and downloaded providers (131 MB) — infra, not runtime
infra/.terraform
**/*.tfstate*

# Local tooling / editor / scratch
.claude
scratchpad
