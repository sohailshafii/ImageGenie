# Deploy-time secrets, kept out of git. Copy to .env (gitignored) and fill in:
#
#     cp .env.example .env
#     # edit .env
#
# The deploy scripts (scripts/adopt_schema.sh, wipe_buckets.sh, check_deploy.sh)
# auto-source ./.env when present. For the Terraform step, source it yourself first
# so TF_VAR_* reaches `terraform apply`:
#
#     set -a; source .env; set +a
#     terraform -chdir=infra apply
#
# Everything non-secret (mail_from, project_id, budget) lives in
# infra/terraform.tfvars instead — this file is only for secrets + per-run creds.

# ── Resend (transactional email) ─────────────────────────────────────────────
# Both are per-operator and stay out of the repo. Terraform reads them via the
# TF_VAR_ prefix when you source this file, so do NOT put them in terraform.tfvars.
# The key needs only "Sending access" (least privilege — the app only sends mail).
TF_VAR_mail_from="Your App <noreply@yourdomain.com>"
TF_VAR_resend_api_key=re_your_key_here

# ── Admin bootstrap (scripts/adopt_schema.sh, step 5) ───────────────────────
# The first admin account. Signup is invite-gated and invites need an admin, so
# this is the only way into a fresh database.
IMAGEGENIE_ADMIN_EMAIL=you@example.com
IMAGEGENIE_ADMIN_PASSWORD=change-me

# ── Optional overrides (defaults shown; uncomment only to change) ────────────
# IMAGEGENIE_GCP_PROJECT=imagegenie-pipeline
# IMAGEGENIE_GCP_REGION=us-central1
